# Database (Vercel Postgres / Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# NextAuth / Auth.js — required: use one secret (32+ random chars). Generate: openssl rand -base64 32
AUTH_SECRET=
# Legacy name; used if AUTH_SECRET is empty
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Admin (single owner)
ADMIN_EMAIL=you@example.com
# Prefer B64 — Next.js expands $ in plain values and breaks bcrypt hashes. Run: yarn admin:hash-b64 <password>
ADMIN_PASSWORD_HASH_B64=
# Or raw bcrypt (escape every $ as \), e.g. \$2a\$10\$...
ADMIN_PASSWORD_HASH=

# Amazon Creators API (replaces PA-API; register: https://affiliate-program.amazon.com/creatorsapi/docs/en-us/onboarding/register-for-creators-api)
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_CREDENTIAL_VERSION=
AMAZON_PARTNER_TAG=your-tag-20
# Product marketplace host, e.g. www.amazon.com (US)
AMAZON_MARKETPLACE=www.amazon.com

# Vercel Blob (admin uploads)
BLOB_READ_WRITE_TOKEN=
